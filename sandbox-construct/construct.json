{
  "schema": "als-construct-manifest@1",
  "name": "sandbox",
  "version": 1,
  "migration_strategy": "sequential",
  "lifecycle_strategy": "process-lifecycle",
  "migrations_dir": "migrations",
  "source_paths": [
    { "path": "VERSION", "owner": "vendor" },
    { "path": "construct.json", "owner": "vendor" },
    { "path": "package.json", "owner": "vendor" },
    { "path": "tsconfig.json", "owner": "vendor" },
    { "path": "src", "owner": "vendor" },
    { "path": "migrations", "owner": "vendor" }
  ]
}
